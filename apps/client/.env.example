# Copy to `.env.local` for dev. Vite only exposes vars prefixed with VITE_.

# Where the better-auth client posts to. Leave unset in dev — Vite proxies
# `/api/*` to http://localhost:3000 (see vite.config.ts).
# VITE_API_URL=http://localhost:3000

# Used for the GitHub OAuth callbackURL. Leave unset to fall back to
# window.location.origin.
# VITE_APP_URL=http://localhost:5173
