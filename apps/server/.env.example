# Copy to `.env` (dev) and `.env.production` (prod) and fill in the values.

# better-auth — required.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated client origins allowed by CORS and better-auth.
TRUSTED_ORIGINS=http://localhost:5173

# SQLite file location (relative to apps/server/).
DATABASE_PATH=data.db

# Optional GitHub OAuth — only enabled if both are set.
# Create at https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
