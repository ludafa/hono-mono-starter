# Server-only secrets. Copy to apps/server/.env (gitignored).
# Shared values (SERVER_PORT, SERVER_URL, CLIENT_URL) live in the root
# .env (see <repo>/.env.example) so the client can read them too.

# Required: better-auth signing secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Optional: GitHub OAuth. Both must be set to enable the provider.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
