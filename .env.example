# Shared dev/build configuration consumed by BOTH server and client.
# Copy this file to `.env` (gitignored). Keep secrets out of this file —
# put server-only secrets in `apps/server/.env` instead.

# Ports the dev servers bind to.
SERVER_PORT=3000
CLIENT_PORT=5173

# Public URLs used for auth callbacks, CORS, and the client API base.
# In production, set these to the deployed origins.
SERVER_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
